# Copy to .env and fill from your Supabase project (Settings → API / Database).
# .env is git-ignored — never commit real keys.

# Supabase (Step 2 of SUPABASE_SETUP.md)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# OTP settings (optional — defaults are sensible)
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6
# OTP delivery transport: console (log code + return devCode, no SMS cost) | twilio
OTP_TRANSPORT=console
# When OTP_TRANSPORT=twilio, set these:
# TWILIO_SID=
# TWILIO_AUTH=
# TWILIO_FROM=

# Storage bucket names (Step 4)
SUPABASE_BUCKET_LISTINGS=listings
SUPABASE_BUCKET_REELS=reels

# AI photo classification (vision) — set ONE of these (server-side only).
# Gemini is free: https://aistudio.google.com → Get API key
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Identity / KYC. IDENTITY_SALT secures the one-person-one-identity hash.
# KYC_PROVIDER + KYC_API_KEY enable real document verification (Onfido/Persona/
# HyperVerge). If unset, identity submits go to the Ops manual-review queue.
IDENTITY_SALT=
KYC_PROVIDER=
KYC_API_KEY=

# Later (Step 6) — server-side only
GOOGLE_MAPS_KEY=

# Server
PORT=4000
